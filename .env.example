# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=moiredb

# Serial sensor connection
SERIAL_PORT=/dev/ttyACM1
SERIAL_PASSWORD=your_serial_password_here

# Set this to the Heroku frontend URL once deployed (e.g. https://your-app.herokuapp.com)
CORS_ORIGIN=https://your-heroku-app.herokuapp.com

PORT=8080
